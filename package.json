{
  "name": "archimate-viewer",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:api\" \"npm:dev:vite\"",
    "dev:vite": "vite",
    "dev:api": "node server/git-api.mjs",
    "dev:ui-only": "vite",
    "dev:wails": "wails dev",
    "build": "vite build",
    "bundle:api": "node scripts/bundle-git-api.mjs",
    "build:desktop": "npm run bundle:api && vite build",
    "build:mac": "CGO_ENABLED=1 wails build -platform darwin/universal -ldflags \"-w -s -extldflags '-framework UniformTypeIdentifiers'\"",
    "build:win": "wails build -platform windows/amd64",
    "start:app": "npm run build:desktop && wails build -devtools -skipbindings -o /tmp/archimate-viewer-dev",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "antd": "^6.4.3",
    "express": "^4.21.2",
    "linkedom": "^0.18.12",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.14.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.60.0",
    "@typescript-eslint/parser": "^8.60.0",
    "@vitejs/plugin-react": "^4.3.3",
    "concurrently": "^9.1.2",
    "esbuild": "^0.25.0",
    "eslint": "^9.14.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.14",
    "globals": "^15.11.0",
    "typescript": "^6.0.3",
    "vite": "^5.4.10"
  }
}
